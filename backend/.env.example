# Microsoft Azure AD SSO
# Créer une App Registration sur https://portal.azure.com
# Redirect URI à configurer : http://localhost:8080/api/auth/microsoft/callback

AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL de l'app (en prod, mettre l'URL publique)
APP_URL=http://localhost:8080
