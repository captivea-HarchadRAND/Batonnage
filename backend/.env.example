# URL publique de l'application (liens dans les emails d'invitation)
APP_URL=https://batonnage.captivea.mg

# ─── SMTP — envoi des emails d'invitation ───────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@captivea.mg
SMTP_PASS=votre_mot_de_passe
SMTP_FROM=Batonnage <noreply@captivea.mg>

# ─── Microsoft Azure AD SSO ─────────────────────────────────────────────────
# Créer une App Registration sur https://portal.azure.com
# Redirect URI : https://batonnage.captivea.mg/api/auth/microsoft/callback
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

FRONTEND_URL=https://batonnage.captivea.mg
